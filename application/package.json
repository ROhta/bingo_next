{
	"name": "bingo_next",
	"version": "1.1.0",
	"private": false,
	"author": "ROhta",
	"description": "A Bingo Machine for Party",
	"license": "GPL-3.0-or-later",
	"homepage": "https://rohta-bingo-next.vercel.app/",
	"repository": {
		"type": "git",
		"url": "https://github.com/ROhta/bingo_next"
	},
	"bugs": {
		"url": "https://github.com/ROhta/bingo_next/security/policy"
	},
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"prepare": "cd .. && husky application/.husky",
		"pretest": "playwright install chromium --with-deps",
		"test": "vitest",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"chromatic": "chromatic --only-changed --project-token=${CHROMATIC_PROJECT_TOKEN}",
		"copilot": "copilot"
	},
	"packageManager": "pnpm@11.5.2",
	"husky": {
		"hooks": {
			"pre-commit": "lint-staged"
		}
	},
	"lint-staged": {
		"*.{ts,tsx,mjs,cjs}": [
			"pnpm exec eslint --fix",
			"pnpm exec prettier --write"
		],
		"*.{html,css,json,md}": [
			"pnpm exec prettier --write"
		],
		"!(pnpm-lock).{yml,yaml}": [
			"pnpm exec prettier --write"
		]
	},
	"prettier": {
		"printWidth": 1000,
		"tabWidth": 2,
		"useTabs": true,
		"semi": false,
		"singleQuote": false,
		"quoteProps": "as-needed",
		"trailingComma": "all",
		"bracketSpacing": false,
		"bracketSameLine": false,
		"arrowParens": "avoid",
		"requirePragma": false,
		"insertPragma": false,
		"proseWrap": "always",
		"htmlWhitespaceSensitivity": "css",
		"singleAttributePerLine": false,
		"embeddedLanguageFormatting": "auto",
		"objectWrap": "preserve",
		"experimentalOperatorPosition": "end",
		"endOfLine": "lf"
	},
	"dependencies": {
		"@radix-ui/react-slot": "^1.2.5",
		"@vercel/analytics": "^2.0.1",
		"@vercel/speed-insights": "^2.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"next": "^16.2.9",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.2.1",
		"@eslint-react/eslint-plugin": "^5.8.19",
		"@github/copilot": "^1.0.61",
		"@storybook/addon-mcp": "~0.6.0",
		"@storybook/addon-vitest": "~10.4.4",
		"@storybook/nextjs-vite": "~10.4.4",
		"@tailwindcss/postcss": "^4.3.0",
		"@testing-library/react": "^16.3.2",
		"@tsconfig/strictest": "^2.0.8",
		"@types/node": "^25.9.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitest/browser": "~4.1.8",
		"@vitest/browser-playwright": "~4.1.8",
		"@vitest/coverage-v8": "~4.1.8",
		"@vitest/eslint-plugin": "^1.6.20",
		"chromatic": "^17.4.1",
		"esbuild": "^0.28.1",
		"eslint": "^10.4.1",
		"eslint-config-next": "^16.2.9",
		"eslint-import-resolver-typescript": "^4.4.5",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-perfectionist": "^5.9.0",
		"eslint-plugin-react-compiler": "^19.1.0-rc.2",
		"eslint-plugin-storybook": "~10.4.4",
		"eslint-plugin-unicorn": "^65.0.1",
		"eslint-plugin-unused-imports": "^4.4.1",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.7",
		"playwright": "^1.60.0",
		"postcss": "^8.5.15",
		"prettier": "^3.8.4",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"storybook": "~10.4.4",
		"tailwindcss": "^4.3.0",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vitest": "~4.1.8"
	}
}
